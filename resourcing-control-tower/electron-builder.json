{
  "appId": "com.resourcing.controltower",
  "productName": "Resource Assignation System (RAS)",
  "directories": {
    "output": "release"
  },
  "afterPack": "build/afterPack.js",
  "files": [
    "dist/**/*",
    "electron/**/*",
    "build/icon.ico",
    "build/icon.png",
    "package.json"
  ],
  "extraResources": [
    {
      "from": "data",
      "to": "data",
      "filter": [
        "**/*"
      ]
    }
  ],
  "win": {
    "target": "nsis",
    "icon": "build/icon.ico",
    "signAndEditExecutable": false,
    "artifactName": "${productName}-${version}-Setup.${ext}"
  },
  "nsis": {
    "oneClick": false,
    "allowToChangeInstallationDirectory": true,
    "createDesktopShortcut": true,
    "createStartMenuShortcut": true
  }
}
